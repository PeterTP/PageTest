    <h1 slot="title" class="!text-[clamp(2rem,11.2vw,3rem)] sm:!text-5xl md:!text-6xl lg:!text-7xl">
      <span class="text-brand-600 dark:text-foreground [-webkit-text-fill-color:currentColor] whitespace-nowrap">The Neuromorphic <br />Research Nexus</span>
    </h1>

    <p slot="description">
      Fusing brain-inspired hardware with advanced software, pioneering the future of artificial intelligence.
    </p>

   <Fragment slot="actions">
